#!/bin/bash
#Bash scripting

# Installing Kraken2
conda install -c bioconda kraken2
kraken2 --version
version 2.17.1           
Build pl5321h077b44d_0
Copyright 2013-2023, Derrick Wood (dwood@cs.jhu.edu)

#Installing a database
mkdir kraken2_db && cd kraken2_db
mkdir standard_8 && cd standard_8

# downloading the Standard-8 (8 GB) database, last updated febuary 2026
wget https://genome-idx.s3.amazonaws.com/kraken/k2_standard_08_GB_20260226.tar.gz

#Extracting 
tar -xzvf k2_standard_08_GB_20260226.tar.gz 

#Checking contents
ls ~/kraken2_db/standard/
should see
hash.k2d -> The k-mer hash table (the big one, ~8 GB)
opts.k2d  -> Database build options
taxo.k2d -> Taxonomy information

#Randomly selecting 3 high NRCD patients from the 39 used in the study
awk -F'\t' '$3 == "high-NRCD" {print $1"\t"$2"\t"$3}' metadata_table.tsv > high_nrcd_all.txt
shuf -n 5 high_nrcd_all.txt > high_nrcd_selected.txt

cat high_nrcd_selected.txt
ERR12025082	1807	high-NRCD
ERR12025102	1837	high-NRCD
ERR12025074	1797	high-NRCD

#Randomly selecting 3 out of the 49 control samples used in the study
shuf -n 5 tCD_controls_metadata.tsv > tCD_selected.txt

cat tCD_selected.txt
SRR22402259	Cii071	tCD_control
SRR22402265	Cii045	tCD_control
SRR22402328	CMa003	tCD_control

echo "    High-NRCD selected    " > selection_log.txt
cat high_nrcd_selected.txt >> selection_log.txt
echo "    tCD controls selected    " >> selection_log.txt
cat tcd_selected.txt >> selection_log.txt

cat selection_log.txt
   High-NRCD selected    
ERR12025082	1807	high-NRCD
ERR12025102	1837	high-NRCD
ERR12025074	1797	high-NRCD

    tCD controls selected     
SRR22402259	Cii071	tCD_control
SRR22402265	Cii045	tCD_control
SRR22402328	CMa003	tCD_control


#Downloading the seleted high-NRCD samples from ENA
for run in ERR12025082 ERR12025102 ERR12025074 ERR12025109 ERR12025104; do
    echo "Getting URLs for $run..."
    urls=$(wget -qO- "https://www.ebi.ac.uk/ena/portal/api/filereport?accession=${run}&result=read_run&fields=fastq_ftp&format=tsv" \
           | tail -1 | cut -f2 | tr ';' '\n')
    
    # Download each file
    for url in $urls; do
        wget -c -P ~assignment_03/metagenomics/high_nrcd "ftp://${url}"
    done
    echo "Done $run"
done

#Downloading the tCD controls from the ENA database browser
for run in SRR22402259 SRR22402265 SRR22402328 SRR22402331 SRR22402374; do
    echo "$(date): Downloading $run..."
    urls=$(wget -qO- "https://www.ebi.ac.uk/ena/portal/api/filereport?accession=${run}&result=read_run&fields=fastq_ftp&format=tsv" \
           | tail -1 | cut -f2 | tr ';' '\n')
    
    for url in $urls; do
        wget -c "ftp://${url}"
    done
    echo "$(date): Done $run"
done


#Quality Control
fastqc ~/binf_6110/assignment_03/metagenomics/high_nrcd/*.fastq.gz \
       ~/binf_6110/assignment_03/metagenomics/tcd/*.fastq.gz \
       --outdir ~/binf_6110/assignment_03/metagenomics/qc/raw \
       --threads 4

conda install -c bioconda multiqc -y

multiqc ~/binf_6110/assignment_03/metagenomics/qc/raw \
        --outdir ~/binf_6110/assignment_03/metagenomics/qc/raw

#Kraken2
mkdir -p ~/binf_6110/assignment_03/metagenomics/kraken2/high_nrcd
mkdir -p ~/binf_6110/assignment_03/metagenomics/kraken2/tcd

#Running Kraken2 on the high-NRCD samples
for run in ERR12025082 ERR12025102 ERR12025074; do
    echo "$(date): Running Kraken2 on $run..."
    kraken2 --db ~/binf_6110/assignment_03/kraken2_db/standard_8 \
            --paired \
            --gzip-compressed \
            --confidence 0.15 \
            --threads 6 \
            --output ~/binf_6110/assignment_03/metagenomics/kraken2/high_nrcd/${run}.kraken \
            --report ~/binf_6110/assignment_03/metagenomics/kraken2/high_nrcd/${run}.report \
            ~/binf_6110/assignment_03/metagenomics/high_nrcd/${run}_1.fastq.gz \
            ~/binf_6110/assignment_03/metagenomics/high_nrcd/${run}_2.fastq.gz
    echo "$(date): Done $run"
done

#Watching analysis progress
watch -n 10 "echo '=== Completed samples ==='; \
ls -lh ~/binf_6110/assignment_03/metagenomics/kraken2/high_nrcd/*.report 2>/dev/null; \
echo ''; \
echo '=== Count ==='; \
ls ~/binf_6110/assignment_03/metagenomics/kraken2/high_nrcd/*.report 2>/dev/null | wc -l"

#Running Kraken2 on the tCD control samples
for run in SRR22402259 SRR22402265 SRR22402328; do
    echo "$(date): Running Kraken2 on $run..."
    kraken2 --db ~/binf_6110/assignment_03/kraken2_db/standard_8 \
            --paired \
            --gzip-compressed \
            --confidence 0.15 \
            --threads 6 \
            --output ~/binf_6110/assignment_03/metagenomics/kraken2/tcd/${run}.kraken \
            --report ~/binf_6110/assignment_03/metagenomics/kraken2/tcd/${run}.report \
            ~/binf_6110/assignment_03/metagenomics/tcd/${run}_1.fastq.gz \
            ~/binf_6110/assignment_03/metagenomics/tcd/${run}_2.fastq.gz
    echo "$(date): Done $run"
done
